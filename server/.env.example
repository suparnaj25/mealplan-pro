# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/mealplan_pro

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this

# Recipe APIs
SPOONACULAR_API_KEY=your-spoonacular-api-key

# Kroger API (https://developer.kroger.com)
KROGER_CLIENT_ID=your-kroger-client-id
KROGER_CLIENT_SECRET=your-kroger-client-secret
KROGER_REDIRECT_URI=http://localhost:5173/auth/kroger/callback

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173